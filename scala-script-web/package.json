{
  "name": "scala-script",
  "version": "0.7.14",
  "displayName": "Scala-Script",
  "description": "Programming language that is mixed Scala and TypeScript's features",
  "author": "Samuel Kang",
  "homepage": "https://github.com/negahama/NegahamaOrg.ScalaScript",
  "license": "MIT",
  "engines": {
    "vscode": "^1.67.0",
    "node": ">=18.0.0"
  },
  "type": "module",
  "files": [
    "out",
    "src"
  ],
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "ScalaScript",
    "TypeScript",
    "compiler",
    "language",
    "Scala"
  ],
  "bugs": {
    "url": "https://github.com/negahama/NegahamaOrg.ScalaScript/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/negahama/NegahamaOrg.ScalaScript.git"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "watch": "tsc -b tsconfig.json --watch",
    "lint": "eslint src --ext ts",
    "langium:generate": "langium generate",
    "langium:watch": "langium generate --watch",
    "build:web": "npm run build",
    "bundle": "vite build",
    "bundle:serve": "http-server ./dist --port 5175",
    "dev": "vite",
    "dev:debug": "vite --debug --force",
    "serve": "npm run dev",
    "test": "vitest run"
  },
  "dependencies": {
    "langium": "~4.2.1",
    "vscode": "npm:@codingame/monaco-vscode-api@~30.0.0",
    "monaco-editor": "npm:@codingame/monaco-vscode-editor-api@~30.0.0",
    "monaco-editor-wrapper": "~6.12.0",
    "monaco-languageclient": "~10.7.0",
    "@codingame/monaco-vscode-editor-service-override": "~30.0.0",
    "@codingame/monaco-vscode-keybindings-service-override": "~30.0.0"
  },
  "devDependencies": {
    "langium-cli": "~4.2.0",
    "typescript": "~6.0.2",
    "eslint": "~10.2.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/parser": "~8.58.0",
    "@typescript-eslint/eslint-plugin": "~8.58.0",
    "@codingame/esbuild-import-meta-url-plugin": "~1.0.3",
    "http-server": "~14.1.1",
    "vite": "~8.0.3",
    "vitest": "~4.1.2"
  },
  "volta": {
    "node": "18.19.1",
    "npm": "10.2.4"
  }
}
