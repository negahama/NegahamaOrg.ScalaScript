{
  "compilerOptions": {
    "target": "ES2017",
    "module": "Node16",
    "lib": ["ESNext"],
    "types": ["node"],
    "sourceMap": true,
    "rootDir": "..",
    "outDir": "out",
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts", "../language/**/*.ts"],
  "exclude": ["out", "node_modules"]
}
